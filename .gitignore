*.pyc
*.pyo
*.pyd
.Python
env/
venv/
.venv/
.venv.bak/
pip-log.txt
pip-delete-this-directory.txt

# Coverage reports
coverage/
htmlcov/
.coverage
*.coverage
.coverage.*

# Temporary files
*.tmp
*.temp
*~
.DS_Store
Thumbs.db

# Compression files
*.zip
*.gz
*.tar
*.tgz
*.bz2
*.xz
*.7z
*.rar
*.zst
*.lz4
*.lzh
*.cab
*.arj
*.rpm
*.deb
*.Z
*.lz
*.lzo
*.tar.gz
*.tar.bz2
*.tar.xz
*.tar.zst
```
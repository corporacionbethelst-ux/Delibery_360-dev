# ============================================
# DELIVERY360 - .gitignore Global
# ============================================

# --- Dependencias (Lo más pesado) ---
/node_modules
/frontend/node_modules
/backend/__pycache__
/backend/**/__pycache__
/*.pyc
/*.pyo
/*.pyd
.Python
env/
venv/
.venv/
pip-log.txt
pip-delete-this-directory.txt

# --- Build Outputs (Generados por Next.js y Python) ---
.next/
/out/
/build/
dist/
*.egg-info/
.eggs/

# --- Logs y Caché ---
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.eslintcache
.mypy_cache/
.pytest_cache/
.coverage
htmlcov/

# --- Entornos Locales (Credenciales) ---
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
backend/.env
frontend/.env.local

# --- IDE y Editores ---
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# --- Docker (Opcional: si no quieres subir configs locales) ---
# .docker/

# --- Datos de Base de Datos (Volúmenes locales si los hubiera) ---
# Asegura que los datos solo vivan en volúmenes de Docker, no en el repo
*.db
*.sqlite
*.sqlite3

# --- Archivos Temporales ---
tmp/
temp/
.cache/

# Compressed
*.zip
*.gz
*.tar
*.tgz
*.bz2
*.xz
*.7z
*.rar
*.zst
*.lz4
*.lzh
*.cab
*.arj
*.rpm
*.deb
*.Z
*.lz
*.lzo
*.tar.gz
*.tar.bz2
*.tar.xz
*.tar.zst
```